# Chatterbox Manga Studio production environment template
CMS_AUTH_REQUIRED=true
CMS_API_KEYS=replace-this-admin-key:admin,replace-this-operator-key:operator
CMS_JWT_SECRET=replace-with-a-long-random-secret

CMS_STORAGE_BACKEND=filesystem
CMS_STORAGE_ROOT=/app/data/storage

# Optional external infrastructure routing (filesystem remains default/fallback)
CMS_PROJECTS_STORAGE_BACKEND=postgresql
CMS_PROJECTS_STORAGE_URL=postgresql://chatterbox:change-me@postgres:5432/chatterbox
CMS_UPLOADS_STORAGE_BACKEND=s3
CMS_UPLOADS_S3_BUCKET=uploads
CMS_UPLOADS_S3_ENDPOINT_URL=http://minio:9000
CMS_ARTIFACTS_STORAGE_BACKEND=s3
CMS_ARTIFACTS_S3_BUCKET=artifacts
CMS_ARTIFACTS_S3_ENDPOINT_URL=http://minio:9000
CMS_CHECKPOINTS_STORAGE_BACKEND=redis
CMS_CHECKPOINTS_STORAGE_URL=redis://redis:6379/0

POSTGRES_DB=chatterbox
POSTGRES_USER=chatterbox
POSTGRES_PASSWORD=change-me
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio

# Provider keys remain mounted/managed as secrets where possible.
